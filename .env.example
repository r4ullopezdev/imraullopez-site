# Correo (SMTP) para el aviso automatico de leads del formulario.
# Si estas variables estan definidas, cada lead llega a SMTP_TO.
SMTP_HOST=smtp.serviciodecorreo.es
SMTP_PORT=465
SMTP_USER=hola@infraestructuraia.com
SMTP_PASS=
SMTP_TO=hola@infraestructuraia.com
