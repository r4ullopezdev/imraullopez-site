NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_WHATSAPP_URL=

# Opcional: si se define, el formulario de contacto reenvia cada lead (POST JSON)
# a esta URL (webhook de n8n, CRM o servicio de email).
